#!/bin/bash
set -e # 遇到错误立即退出

# ================= 0. 基础变量配置 =================
EXP_NAME="cephmango"
DOMAIN="${EXP_NAME}.isu-cloud.emulab.net"
NET_IFACE="eno4"    # 请确认这是您的真实网卡名称
CEPH_VER="reef"
REPO_TAG="stable-8.0"

echo ">>> [1/11] 环境检查: 测试外网连接..."
if ping -c 2 galaxy.ansible.com > /dev/null 2>&1; then
    echo "Network OK."
else
    echo "警告: 无法连接到 galaxy.ansible.com，依赖下载可能会失败。"
fi

echo ">>> [2/11] 安装系统基础依赖..."
sudo apt update
sudo apt install -y python3 python3-pip git ansible
ansible --version

echo ">>> [3/11] 下载 Ceph-Ansible 代码库..."
if [ ! -d "ceph-ansible" ]; then
    git clone https://github.com/ceph/ceph-ansible.git
fi
cd ceph-ansible
git fetch --all
git checkout $REPO_TAG
echo "当前分支: $(git branch --show-current)"

echo ">>> [4/11] 安装 Python 依赖和 Ansible Collections..."
pip3 install -r requirements.txt
ansible-galaxy install -r requirements.yml || echo "警告: Galaxy 安装遇到问题，尝试继续..."
ansible-galaxy collection install ansible.posix
ansible-galaxy collection install community.general

echo ">>> [5/11] 初始化配置目录..."
mkdir -p inventory host_vars group_vars
cp site.yml.sample site.yml
cp group_vars/all.yml.sample group_vars/all.yml
cp group_vars/mons.yml.sample group_vars/mons.yml
cp group_vars/osds.yml.sample group_vars/osds.yml
cp group_vars/mgrs.yml.sample group_vars/mgrs.yml
cp group_vars/mdss.yml.sample group_vars/mdss.yml
cp group_vars/clients.yml.sample group_vars/clients.yml

echo ">>> [6/11] 生成 Inventory 文件 (14节点拓扑)..."
cat > inventory/hosts <<EOF
[mons]
node2.${DOMAIN} ansible_host=10.10.1.3
node3.${DOMAIN} ansible_host=10.10.1.4
node4.${DOMAIN} ansible_host=10.10.1.5

[mgrs]
node2.${DOMAIN} ansible_host=10.10.1.3

[mdss]
node2.${DOMAIN} ansible_host=10.10.1.3

[osds]
EOF

# 自动生成 12 个 OSD 节点 (node2 - node13)
for i in {2..13}; do
    echo "node${i}.${DOMAIN} ansible_host=10.10.1.$((i+1))" >> inventory/hosts
done

cat >> inventory/hosts <<EOF

[clients]
# node0 是本地管理节点
node0.${DOMAIN} ansible_host=10.10.1.1 ansible_connection=local
node1.${DOMAIN} ansible_host=10.10.1.2

[monitoring]
node2.${DOMAIN} ansible_host=10.10.1.3

[ceph:children]
mons
osds
mgrs
mdss
clients
monitoring

[ceph:vars]
ansible_user=root
ansible_ssh_private_key_file=~/.ssh/id_rsa
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
EOF

echo ">>> [7/11] 配置全局变量 (all.yml)..."
cat > group_vars/all.yml <<EOF
---
ceph_origin: repository
ceph_repository: community
ceph_stable_release: ${CEPH_VER}
public_network: "10.10.1.0/24"
cluster_network: "10.10.1.0/24"
monitor_address_block: "10.10.1.0/24"
monitor_interface: ${NET_IFACE}
radosgw_interface: ${NET_IFACE}
fsid: "{{ ansible_date_time.epoch | to_uuid }}"
cephx: true
containerized_deployment: false
dashboard_enabled: true
dashboard_admin_user: admin
dashboard_admin_password: password
grafana_admin_user: admin
grafana_admin_password: admin
monitoring_stack_enabled: false
ansible_ssh_user: root
ansible_become: true
gather_facts: true

# 【关键修复】跳过 Ceph-Ansible 官方部署工具变动的拦截警告
ceph_ansible_disclaimer: true

# 【关键修复】禁用 Handler 健康检查，防止部署时死锁
handler_health_check: false

# 全局开启 PG 自动伸缩
ceph_conf_overrides:
  global:
    osd_pool_default_pg_autoscale_mode: on
EOF

echo ">>> [8/11] 配置角色变量..."
# Mons
cat > group_vars/mons.yml <<EOF
---
monitor_address_block: "10.10.1.0/24"
monitor_address: "{{ ansible_host }}"
ms_bind_msgr2: true
EOF

# OSDs (1 OSD per host)
cat > group_vars/osds.yml <<EOF
---
osd_auto_discovery: false
osd_scenario: lvm
osd_objectstore: bluestore
devices:
  - /dev/sdb
EOF

# Mgrs
cat > group_vars/mgrs.yml <<EOF
---
ceph_mgr_modules: [dashboard, prometheus, iostat, restful]
ceph_mgr_dashboard_port: 8443
ceph_mgr_dashboard_server_addr: "0.0.0.0"
EOF

# MDSs
cat > group_vars/mdss.yml <<EOF
---
# 基础配置
EOF

echo ">>> [9/11] 配置 Clients (clients.yml)..."
cat > group_vars/clients.yml <<EOF
---
copy_admin_key: true
user_config: true
ceph_pools:
  - { name: "rbd", pg_num: 32, application: "rbd", size: 3 }
  - { name: "cephfs_data", pg_num: 32, application: "cephfs", size: 3 }
  - { name: "cephfs_metadata", pg_num: 16, application: "cephfs", size: 3 }
cephfs_data_pool: { name: cephfs_data }
cephfs_metadata_pool: { name: cephfs_metadata }
ceph_fs: cephfs
EOF

echo ">>> [10/11] 最终预检 (Ping)..."
ansible -i inventory/hosts all -m ping

echo ">>> [11/11] 开始部署 Ceph Reef..."
# 使用 -e 再次确保免责确认生效
ansible-playbook -i inventory/hosts site.yml -v \
  -e "handler_health_check=false" \
  -e "ceph_ansible_disclaimer=true"

echo "=============================================="
echo ">>> 部署结束！"
sudo ceph -s
sudo ceph osd tree
echo "=============================================="