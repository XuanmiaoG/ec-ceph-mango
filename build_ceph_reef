#!/bin/bash
set -e

# ================= 0. 基础变量配置 =================
EXP_NAME="cephmango"
DOMAIN="${EXP_NAME}.isu-cloud.emulab.net"
NET_IFACE="eno4"    # 请确认网卡名称
CEPH_VER="reef"     # 保持 Reef 版本
REPO_TAG="stable-8.0"

echo ">>> [1/11] 环境检查: 测试外网连接..."
ping -c 2 galaxy.ansible.com > /dev/null 2>&1 || echo "警告: Galaxy 连接可能受限"

echo ">>> [2/11] 安装系统基础依赖..."
sudo apt update
sudo apt install -y python3 python3-pip git ansible
ansible --version

echo ">>> [3/11] 下载 Ceph-Ansible 代码库..."
if [ ! -d "ceph-ansible" ]; then
    git clone https://github.com/ceph/ceph-ansible.git
fi
cd ceph-ansible
git fetch --all
git checkout $REPO_TAG

echo ">>> [4/11] 安装 Python 依赖和 Ansible Collections..."
pip3 install -r requirements.txt
ansible-galaxy install -r requirements.yml || echo "Galaxy 安装警告(忽略)"
ansible-galaxy collection install ansible.posix
ansible-galaxy collection install community.general

echo ">>> [5/11] 初始化配置目录..."
mkdir -p inventory host_vars group_vars
cp site.yml.sample site.yml
# 复制并覆盖默认变量文件
[ -f group_vars/all.yml.sample ] && cp group_vars/all.yml.sample group_vars/all.yml
[ -f group_vars/mons.yml.sample ] && cp group_vars/mons.yml.sample group_vars/mons.yml
[ -f group_vars/osds.yml.sample ] && cp group_vars/osds.yml.sample group_vars/osds.yml
[ -f group_vars/mgrs.yml.sample ] && cp group_vars/mgrs.yml.sample group_vars/mgrs.yml
[ -f group_vars/mdss.yml.sample ] && cp group_vars/mdss.yml.sample group_vars/mdss.yml
[ -f group_vars/clients.yml.sample ] && cp group_vars/clients.yml.sample group_vars/clients.yml

echo ">>> [6/11] 生成 Inventory 文件 (严格匹配图片要求)..."
# 拓扑逻辑：
# Clients: node0, node1 (独立)
# Cluster: node2-node13 (12个节点)
#   - Mons: node2, node3, node4 (3个)
#   - Mgr: node2 (1个)
#   - MDS: node2 (1个)
#   - OSDs: node2-node13 (12个, 每节点1个)

cat > inventory/hosts <<EOF
# --- Monitor (3个, 要求 >3 的奇数) ---
[mons]
node2.${DOMAIN} ansible_host=10.10.1.3
node3.${DOMAIN} ansible_host=10.10.1.4
node4.${DOMAIN} ansible_host=10.10.1.5

# --- Manager (1个) ---
[mgrs]
node2.${DOMAIN} ansible_host=10.10.1.3

# --- Metadata Server (1个) ---
[mdss]
node2.${DOMAIN} ansible_host=10.10.1.3

# --- OSDs (12个, 1 OSD per host) ---
[osds]
EOF

# 循环生成 node2 到 node13 (共12个 OSD 节点)
for i in {2..13}; do
    # IP 从 10.10.1.3 (node2) 开始
    echo "node${i}.${DOMAIN} ansible_host=10.10.1.$((i+1))" >> inventory/hosts
done

cat >> inventory/hosts <<EOF

# --- Clients (2个, 独立于 Cluster) ---
[clients]
node0.${DOMAIN} ansible_host=10.10.1.1 ansible_connection=local
node1.${DOMAIN} ansible_host=10.10.1.2

[monitoring]
node2.${DOMAIN} ansible_host=10.10.1.3

[ceph:children]
mons
osds
mgrs
mdss
clients
monitoring

[ceph:vars]
ansible_user=root
ansible_ssh_private_key_file=~/.ssh/id_rsa
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
EOF

echo ">>> [7/11] 配置全局变量 (all.yml)..."
cat > group_vars/all.yml <<EOF
---
ceph_origin: repository
ceph_repository: community
ceph_stable_release: ${CEPH_VER}
public_network: "10.10.1.0/24"
cluster_network: "10.10.1.0/24"
monitor_address_block: "10.10.1.0/24"
monitor_interface: ${NET_IFACE}
radosgw_interface: ${NET_IFACE}
fsid: "{{ ansible_date_time.epoch | to_uuid }}"
cephx: true
containerized_deployment: false
dashboard_enabled: true
dashboard_admin_user: admin
dashboard_admin_password: password
grafana_admin_user: admin
grafana_admin_password: admin
monitoring_stack_enabled: false
ansible_ssh_user: root
ansible_become: true
gather_facts: true
# 关键：防止单 OSD 启动时的死锁检查，虽然我们有12个，但安全起见保留
handler_health_check: false
ceph_conf_overrides:
  global:
    osd_pool_default_pg_autoscale_mode: on
EOF

echo ">>> [8/11] 配置角色变量..."

# Mons
cat > group_vars/mons.yml <<EOF
---
monitor_address_block: "10.10.1.0/24"
monitor_address: "{{ ansible_host }}"
ms_bind_msgr2: true
EOF

# OSDs (确保每个节点只用一块盘 /dev/sdb)
cat > group_vars/osds.yml <<EOF
---
osd_auto_discovery: false
osd_scenario: lvm
osd_objectstore: bluestore
devices:
  - /dev/sdb
ceph_osd_docker_memory_limit: 4294967296
EOF

# Mgrs
cat > group_vars/mgrs.yml <<EOF
---
ceph_mgr_modules:
  - dashboard
  - prometheus
  - iostat
  - restful
ceph_mgr_dashboard_port: 8443
ceph_mgr_dashboard_server_addr: "0.0.0.0"
EOF

# MDSs (CephFS 需要)
cat > group_vars/mdss.yml <<EOF
---
ceph_mgr_dashboard_port: 8443
EOF

echo ">>> [9/11] 配置 Clients (clients.yml)..."
cat > group_vars/clients.yml <<EOF
---
copy_admin_key: true
user_config: true
ceph_pools:
  - name: "rbd"
    pg_num: 32
    pg_autoscale_mode: on
    type: 1
    application: "rbd"
    size: 3
    min_size: 1
  - name: "cephfs_data"
    pg_num: 32
    pg_autoscale_mode: on
    type: 1
    application: "cephfs"
    size: 3 # 副本数 3，因为我们现在有 12 个 OSD，足够安全
    min_size: 1
  - name: "cephfs_metadata"
    pg_num: 16
    pg_autoscale_mode: on
    type: 1
    application: "cephfs"
    size: 3
    min_size: 1

cephfs_data_pool:
  name: cephfs_data
cephfs_metadata_pool:
  name: cephfs_metadata
ceph_fs: cephfs
EOF

echo ">>> [10/11] 最终预检..."
# 检查所有节点的连通性
ansible -i inventory/hosts all -m ping

echo ">>> [11/11] 开始部署 Ceph Reef (符合图片拓扑)..."
echo ">>> Topology: 2 Clients, 3 Mons, 1 Mgr, 1 MDS, 12 OSDs (1 per host)"
sleep 3

ansible-playbook -i inventory/hosts site.yml -v -e "handler_health_check=false"

echo "=============================================="
echo ">>> 部署结束！请检查以下状态："
echo "1. Client 节点 (node0, node1) 是否有 /etc/ceph/ceph.conf"
echo "2. OSD 树形图是否显示 12 个 OSD: 'sudo ceph osd tree'"
echo "3. Quorum 是否包含 3 个 Monitor: 'sudo ceph -s'"
echo "=============================================="
